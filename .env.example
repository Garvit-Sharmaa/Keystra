# ========================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ========================

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Frontend (apps/web) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Backend (apps/api) ──────────────────────────────────────────────────────
API_PORT=4000
API_SECRET_KEY=replace_with_a_very_long_random_secret_key_min_32_chars

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=typingmaster
POSTGRES_PASSWORD=typingmaster_dev_password
POSTGRES_DB=typingmaster
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://typingmaster:typingmaster_dev_password@localhost:5432/typingmaster

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_another_very_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── OAuth: Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── OAuth: GitHub ───────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── BullMQ / Queue ──────────────────────────────────────────────────────────
QUEUE_ANALYTICS=analytics
QUEUE_ACHIEVEMENTS=achievements
QUEUE_STREAKS=streaks
QUEUE_ARCHIVAL=archival

# ─── Observability (optional, for production) ─────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=
LOG_LEVEL=info
